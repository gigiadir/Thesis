# R data and serialized objects (not source)
*.RData
*.rda
*.rds
*.RDS

# R session / local preferences
.Rhistory
.Rprofile
.Renviron
.Rapp.history

# Claude (local state; not project source)
.claude/
.claude.json

# Logs
*.log
logs/

# Plots and common figure / report outputs
*.png
*.pdf
*.jpg
*.jpeg
*.svg
*.tiff
*.tif
*.eps
*.html

# Environments and IDE (not project source)
.conda/
.cursor-server/
.cursor/
.cache/
.local/
.config/
.vscode/
.vscode-R/

# R user library under this tree
R/

# Shell, editor, and personal dotfiles (do not version)
.bash_history
.bash_profile
.bashrc
.cshrc
.sh_history
.radian_history
.viminfo
.lesshst
.gitconfig
.sleep.sh.e
.sleep.sh.o

# Secrets / machine-local
.ssh/
.git-credentials
.netrc

# Kubernetes
.kube/

# RStudio per-user project state (safe to ignore)
.Rproj.user/
*.Rproj

# Bundles / manifests / large archives
*.tar.gz
MANIFEST.txt

# Analysis outputs and vendored CIBERSORT package trees
**/output/
**/outputs/
**/CIBERSORT_package/
**/CIBERSORT-Results.txt

# Local scratch / object lists
Scripts/Missing-scDiffCom-Objects

# Conda export dirs (recreate from yaml if needed)
conda-environments/

# Large / local preprocessing tree (not tracked as code here)
CCC-PreProcess/

# Thesis analysis outputs / Dropbox symlinks (with or without trailing slash)
Thesis/CCC/outputs
Thesis/Figure 1 - Bulk/outputs

# Root smoke scripts
/test.sh

# OS / misc
.DS_Store
*.swp
*~

# Post-analysis R helpers (override global R/ ignore)
!Thesis/CCC/scripts/scDiffCom/post_analysis/R/
!Thesis/CCC/scripts/scDiffCom/post_analysis/R/**

# Preprocessing-checks R helpers (override global R/ ignore)
!Thesis/CCC/scripts/scDiffCom/preprocess/preprocessing_checks/R/
!Thesis/CCC/scripts/scDiffCom/preprocess/preprocessing_checks/R/**

# Generated qsub manifest (regenerate via scDiffCom/pipeline/Main-scDiffComPipeline.R)
Thesis/CCC/scripts/scDiffCom/pipeline/submit_scDiffCom_jobs.sh
Thesis/CCC/scripts/scDiffCom/preprocess/submit_jobs.sh
